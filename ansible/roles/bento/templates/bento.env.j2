SEGMENT_PO2={{ bento_segment_po2 }}
KECCAK_PO2={{ bento_keccak_po2 }}
{% if bento_rewards_address | default('') != '' %}
REWARDS_ADDRESS={{ bento_rewards_address }}
{% endif %}
{% if bento_postgresql_socket_dir | default('') != '' %}
{# Use Unix socket for PostgreSQL #}
DATABASE_URL=postgresql://{{ bento_postgresql_user }}:{{ bento_postgresql_password }}@{{ bento_postgresql_socket_dir }}/{{ bento_postgresql_database }}
{% else %}
{# Use TCP for PostgreSQL #}
DATABASE_URL=postgresql://{{ bento_postgresql_user }}:{{ bento_postgresql_password }}@{{ bento_postgresql_host }}:{{ bento_postgresql_port }}/{{ bento_postgresql_database }}
{% endif %}
{% if bento_valkey_socket | default('') != '' %}
{# Use Unix socket for Valkey/Redis #}
REDIS_URL=redis+unix://{{ bento_valkey_socket }}
{% else %}
{# Use TCP for Valkey/Redis #}
REDIS_URL=redis://{{ bento_valkey_host }}:{{ bento_valkey_port }}
{% endif %}
S3_BUCKET={{ bento_s3_bucket }}
S3_ACCESS_KEY={{ bento_s3_access_key }}
S3_SECRET_KEY={{ bento_s3_secret_key }}
S3_URL={{ bento_s3_url }}
S3_REGION={{ bento_s3_region | default('auto') }}
{% if bento_povw_log_id | default('') != '' %}
POVW_LOG_ID={{ bento_povw_log_id }}
{% endif %}
RUST_LOG={{ bento_rust_log }}

