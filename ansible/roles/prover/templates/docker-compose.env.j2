# Bento Docker Compose Environment Variables
# Generated by Ansible - Do not edit manually

# Docker Runtime (nvidia for GPU hosts, runc for CPU-only)
DOCKER_RUNTIME={{ prover_docker_runtime | default('nvidia') }}

# Database Configuration
POSTGRES_HOST={{ prover_postgres_host }}
POSTGRES_PORT={{ prover_postgres_port }}
POSTGRES_DB={{ prover_postgres_db }}
POSTGRES_USER={{ prover_postgres_user }}
POSTGRES_PASSWORD={{ prover_postgres_password }}

# Redis/Valkey Configuration
REDIS_HOST={{ prover_redis_host }}
REDIS_PASSWORD={{ prover_redis_password }}

# MinIO Configuration
MINIO_HOST={{ prover_minio_host }}
MINIO_BUCKET={{ prover_minio_bucket }}
MINIO_ROOT_USER={{ prover_minio_root_user }}
MINIO_ROOT_PASS={{ prover_minio_root_pass }}

# Bento Configuration
RUST_LOG={{ prover_rust_log }}
NO_COLOR=1
RISC0_HOME={{ prover_risc0_home }}
SEGMENT_SIZE={{ prover_segment_size }}
RISC0_KECCAK_PO2={{ prover_risc0_keccak_po2 }}
REDIS_TTL={{ prover_redis_ttl }}
SNARK_TIMEOUT={{ prover_snark_timeout }}

# Build mode: set to "all" to build from source, empty for pre-built images
{% if prover_boundless_build | default('') | string | length > 0 %}
BOUNDLESS_BUILD={{ prover_boundless_build }}
{% else %}
BOUNDLESS_BUILD=
{% endif %}

# Docker image configuration
{% if prover_stack | default('') == 'experimental' %}
{# prover-compose.yml uses PROVER_* image/dockerfile variable names #}
{% if prover_image_tag | default('') | string | length > 0 %}
# Using explicit tag: {{ prover_image_tag }}
PROVER_AGENT_IMAGE=ghcr.io/boundless-xyz/boundless/prover-agent:{{ prover_image_tag }}
PROVER_CPU_AGENT_IMAGE=ghcr.io/boundless-xyz/boundless/prover-agent-cpu:{{ prover_image_tag }}
BROKER_IMAGE=ghcr.io/boundless-xyz/boundless/broker:{{ prover_image_tag }}
PROVER_REST_API_IMAGE=ghcr.io/boundless-xyz/boundless/prover-rest-api:{{ prover_image_tag }}
PROVER_CLI_IMAGE=ghcr.io/boundless-xyz/boundless/prover-cli:{{ prover_image_tag }}
{% elif prover_image_version | default('') | string | length > 0 %}
PROVER_AGENT_IMAGE=ghcr.io/boundless-xyz/boundless/prover-agent:prover-v{{ prover_image_version }}
PROVER_CPU_AGENT_IMAGE=ghcr.io/boundless-xyz/boundless/prover-agent-cpu:prover-v{{ prover_image_version }}
BROKER_IMAGE=ghcr.io/boundless-xyz/boundless/broker:broker-v{{ prover_image_version }}
PROVER_REST_API_IMAGE=ghcr.io/boundless-xyz/boundless/prover-rest-api:prover-v{{ prover_image_version }}
PROVER_CLI_IMAGE=ghcr.io/boundless-xyz/boundless/prover-cli:prover-v{{ prover_image_version }}
{% else %}
PROVER_AGENT_IMAGE=ghcr.io/boundless-xyz/boundless/prover-agent:latest
PROVER_CPU_AGENT_IMAGE=ghcr.io/boundless-xyz/boundless/prover-agent-cpu:latest
BROKER_IMAGE=ghcr.io/boundless-xyz/boundless/broker:latest
PROVER_REST_API_IMAGE=ghcr.io/boundless-xyz/boundless/prover-rest-api:latest
PROVER_CLI_IMAGE=ghcr.io/boundless-xyz/boundless/prover-cli:latest
{% endif %}
{% else %}
{# compose.yml uses the original bento-* image/dockerfile variable names #}
{% if prover_image_tag | default('') | string | length > 0 %}
# Using explicit tag: {{ prover_image_tag }}
AGENT_IMAGE=ghcr.io/boundless-xyz/boundless/bento-agent:{{ prover_image_tag }}
CPU_AGENT_IMAGE=ghcr.io/boundless-xyz/boundless/bento-agent-cpu:{{ prover_image_tag }}
BROKER_IMAGE=ghcr.io/boundless-xyz/boundless/broker:{{ prover_image_tag }}
REST_API_IMAGE=ghcr.io/boundless-xyz/boundless/bento-rest-api:{{ prover_image_tag }}
BENTO_CLI_IMAGE=ghcr.io/boundless-xyz/boundless/bento-cli:{{ prover_image_tag }}
{% elif prover_image_version | default('') | string | length > 0 %}
AGENT_IMAGE=ghcr.io/boundless-xyz/boundless/bento-agent:bento-v{{ prover_image_version }}
CPU_AGENT_IMAGE=ghcr.io/boundless-xyz/boundless/bento-agent-cpu:bento-v{{ prover_image_version }}
BROKER_IMAGE=ghcr.io/boundless-xyz/boundless/broker:broker-v{{ prover_image_version }}
REST_API_IMAGE=ghcr.io/boundless-xyz/boundless/bento-rest-api:bento-v{{ prover_image_version }}
BENTO_CLI_IMAGE=ghcr.io/boundless-xyz/boundless/bento-cli:bento-v{{ prover_image_version }}
{% else %}
AGENT_IMAGE=ghcr.io/boundless-xyz/boundless/bento-agent:latest
CPU_AGENT_IMAGE=ghcr.io/boundless-xyz/boundless/bento-agent-cpu:latest
BROKER_IMAGE=ghcr.io/boundless-xyz/boundless/broker:latest
REST_API_IMAGE=ghcr.io/boundless-xyz/boundless/bento-rest-api:latest
BENTO_CLI_IMAGE=ghcr.io/boundless-xyz/boundless/bento-cli:latest
{% endif %}
{% endif %}

# Dockerfile overrides.
# CPU-only exec/aux agents default to the CPU Dockerfile.
# GPU prove agents default to the CUDA Dockerfile.
{% if prover_stack | default('') == 'experimental' %}
{% if prover_agent_dockerfile is defined and prover_agent_dockerfile | string | length > 0 %}
PROVER_CPU_AGENT_DOCKERFILE={{ prover_agent_dockerfile }}
{% endif %}
{% if prover_gpu_agent_dockerfile is defined and prover_gpu_agent_dockerfile | string | length > 0 %}
PROVER_AGENT_DOCKERFILE={{ prover_gpu_agent_dockerfile }}
{% endif %}
{% if prover_broker_dockerfile is defined and prover_broker_dockerfile | string | length > 0 %}
BROKER_DOCKERFILE={{ prover_broker_dockerfile }}
{% endif %}
{% if prover_rest_api_dockerfile is defined and prover_rest_api_dockerfile | string | length > 0 %}
PROVER_REST_API_DOCKERFILE={{ prover_rest_api_dockerfile }}
{% endif %}
{% else %}
{% if prover_agent_dockerfile is defined and prover_agent_dockerfile | string | length > 0 %}
CPU_AGENT_DOCKERFILE={{ prover_agent_dockerfile }}
{% endif %}
{% if prover_gpu_agent_dockerfile is defined and prover_gpu_agent_dockerfile | string | length > 0 %}
GPU_AGENT_DOCKERFILE={{ prover_gpu_agent_dockerfile }}
{% endif %}
{% if prover_broker_dockerfile is defined and prover_broker_dockerfile | string | length > 0 %}
BROKER_DOCKERFILE={{ prover_broker_dockerfile }}
{% endif %}
{% if prover_rest_api_dockerfile is defined and prover_rest_api_dockerfile | string | length > 0 %}
REST_API_DOCKERFILE={{ prover_rest_api_dockerfile }}
{% endif %}
{% endif %}

# BLAKE3 Groth16 artifacts (required for GPU proving)
{% if prover_blake3_groth16_url is defined and prover_blake3_groth16_url | string | length > 0 %}
BLAKE3_GROTH16_ARTIFACTS_URL={{ prover_blake3_groth16_url }}
{% endif %}

# Set Verifier Address
{% if prover_set_verifier_address is defined and prover_set_verifier_address | string | length > 0 %}
SET_VERIFIER_ADDRESS={{ prover_set_verifier_address }}
{% endif %}
# Boundless Market Address
{% if prover_boundless_market_address is defined and prover_boundless_market_address | string | length > 0 %}
BOUNDLESS_MARKET_ADDRESS={{ prover_boundless_market_address }}
{% endif %}
# Collateral Token Address
{% if prover_collateral_token_address is defined and prover_collateral_token_address | string | length > 0 %}
COLLATERAL_TOKEN_ADDRESS={{ prover_collateral_token_address }}
{% endif %}
# Order Stream URL (skip when per-chain deployments are configured to avoid
# triggering clap's Deployment group requires constraint)
{% if prover_order_stream_url is defined and prover_order_stream_url | string | length > 0 and (prover_chain_deployments | default({}) | length == 0) %}
ORDER_STREAM_URL={{ prover_order_stream_url }}
{% endif %}

# Worker counts
{% if prover_executor_count is defined and prover_executor_count | string | length > 0 %}
BENTO_EXECUTOR_COUNT={{ prover_executor_count }}
{% endif %}
{% if prover_aux_worker_count is defined and prover_aux_worker_count | string | length > 0 %}
BENTO_AUX_WORKER_COUNT={{ prover_aux_worker_count }}
{% endif %}
# Broker Configuration (if enabled)
{% if prover_private_key is defined and prover_private_key | string | length > 0 %}
PROVER_PRIVATE_KEY={{ prover_private_key }}
{% endif %}
{% if prover_povw_log_id is defined and prover_povw_log_id | string | length > 0 %}
POVW_LOG_ID={{ prover_povw_log_id }}
{% endif %}
{% if prover_rpc_url is defined and prover_rpc_url | string | length > 0 %}
PROVER_RPC_URL={{ prover_rpc_url }}
{% endif %}
{% if prover_rpc_urls is defined and prover_rpc_urls | string | length > 0 %}
PROVER_RPC_URLS={{ prover_rpc_urls }}
{% endif %}
{% if prover_chain_rpc_urls is defined and prover_chain_rpc_urls | length > 0 %}
# Per-chain RPC URLs for multichain broker
{% for chain_id, rpc_url in prover_chain_rpc_urls.items() %}
PROVER_RPC_URL_{{ chain_id }}={{ rpc_url }}
{% endfor %}
{% endif %}

# Broker extra CLI args (e.g. --experimental-rpc when prover_broker_experimental_rpc is true)
{% if prover_broker_experimental_rpc | default(false) | bool or (prover_broker_extra_args is defined and prover_broker_extra_args | string | length > 0) %}
BROKER_EXTRA_ARGS={% if prover_broker_experimental_rpc | default(false) | bool %}--experimental-rpc{% endif %}{% if prover_broker_extra_args is defined and prover_broker_extra_args | string | length > 0 %}{% if prover_broker_experimental_rpc | default(false) | bool %} {% endif %}{{ prover_broker_extra_args }}{% endif %}
{% endif %}

# MinIO Input TTL (0 = disabled, >0 = expire inputs/ objects after N days)
INPUT_TTL_DAYS={{ prover_input_ttl_days | default(1) }}

# Caddy Configuration (if using caddy profile)
{% if caddy_domain is defined and caddy_domain | string | length > 0 %}
CADDY_DOMAIN={{ caddy_domain }}
{% endif %}
{% if caddy_acme_email is defined and caddy_acme_email | string | length > 0 %}
CADDY_ACME_EMAIL={{ caddy_acme_email }}
{% endif %}
{% if prover_caddy_file is defined and prover_caddy_file | string | length > 0 %}
CADDYFILE={{ prover_caddy_file }}
{% if caddy_api_key is defined and caddy_api_key | string | length > 0 %}
CADDY_API_KEY={{ caddy_api_key }}
{% endif %}
{% elif caddy_api_key is defined and caddy_api_key | string | length > 0 %}
CADDYFILE=Caddyfile.apikey
CADDY_API_KEY={{ caddy_api_key }}
{% endif %}
