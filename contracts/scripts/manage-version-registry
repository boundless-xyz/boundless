#!/bin/bash

set -eo pipefail

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
SCRIPT_FILE="${SCRIPT_DIR}/Manage.VersionRegistry.s.sol"
REPO_ROOT_DIR="${SCRIPT_DIR:?}/../.."
FIREBLOCKS=0
export FOUNDRY_OUT=${FOUNDRY_OUT:-"contracts/out"}

# Check for python3, required for updating the deployment toml
if ! command -v python3 >/dev/null 2>&1; then
    echo "❌ python3 is not installed"
    exit 1
fi

# Check for tomlkit (Python package), required for updating the deployment toml
if ! python3 -c "import tomlkit" >/dev/null 2>&1; then
    echo "❌ tomlkit is not installed for python3"
    echo "To install: python3 -m pip install tomlkit"
    exit 1
fi

# Check for yq
if ! command -v yq >/dev/null 2>&1; then
    echo "❌ yq is not installed"
    echo "Install yq v4+ from: https://github.com/mikefarah/yq"
    exit 1
fi

POSITIONAL_ARGS=()
FORGE_SCRIPT_FLAGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
    -f|--fireblocks)
        FIREBLOCKS=1
        shift # past argument
        ;;
    --broadcast|--verify)
        FORGE_SCRIPT_FLAGS+=("$1")
        shift
        ;;
    -*|--*)
        echo "Unknown option $1"
        exit 1
        ;;
    *)
        POSITIONAL_ARGS+=("$1") # save positional arg
        shift # past argument
        ;;
    esac
done

set -- "${POSITIONAL_ARGS[@]}" # restore positional parameters

# HINT: deployment_secrets.toml contains API keys. You can write it yourself, or ask a friend.
load_env_var() {
    local var_name="$1"
    local config_key="$2"
    local config_file="$3"

    # Get current value of the variable
    local current_value=$(eval echo \$$var_name)

    if [ -z "$current_value" ]; then
        echo "$var_name from $config_file: " > /dev/stderr
        local new_value=$(yq eval -e "$config_key" "$REPO_ROOT_DIR/contracts/$config_file")
        [ -n "$new_value" ] && [[ "$new_value" != "null" ]] || exit 1
        export $var_name="$new_value"
    else
        echo "$var_name from env $current_value"
    fi
}

# Run a Forge script with support for Fireblocks with options set automatically
forge_script() {
    # Set our function. If the function is "help", or if the function is
    # unspecified, then print some help.
    local script_function="${1:-help}"
    shift

    if [ "${script_function:?}" == "help" ]; then
        cat << EOF
🔧 VersionRegistry Management Script
=====================================

Usage: $0 <command> [options]

Commands:
  DeployVersionRegistry              Deploy the VersionRegistry contract
  UpgradeVersionRegistry             Upgrade the VersionRegistry contract
  SetMinimumBrokerVersion            Set the minimum required broker version
  SetNotice                          Set or clear the governance notice
  TransferVersionRegistryOwnership   Transfer ownership of the VersionRegistry (step 1: initiate)
  AcceptVersionRegistryOwnership     Accept ownership of the VersionRegistry (step 2: complete)

Options:
  -f, --fireblocks       Use Fireblocks for transaction signing
  --broadcast            Broadcast transactions to network
  --verify               Verify contracts on Etherscan
  -h, --help             Show this help message

Environment Variables:
  CHAIN_KEY              Required. Deployment environment key (anvil, ethereum-mainnet, ethereum-sepolia, ethereum-sepolia-staging)
  STACK_TAG              Optional. Stack tag for multi-deployment environments
  DEPLOYER_PRIVATE_KEY   Required. Private key for transaction signing (0x...)
  MAJOR                  Override for SetMinimumBrokerVersion. Major version number (default: from TOML)
  MINOR                  Override for SetMinimumBrokerVersion. Minor version number (default: from TOML)
  PATCH                  Override for SetMinimumBrokerVersion. Patch version number (default: from TOML)
  NOTICE                 Override for SetNotice. Notice text (default: from TOML, empty string to clear)
  NEW_OWNER              Required for TransferVersionRegistryOwnership. New owner address (0x...)
  GNOSIS_EXECUTE         Optional. Set to true to generate Gnosis Safe calldata instead of executing
  SKIP_SAFETY_CHECKS     Optional. Skip upgrade safety checks (use with caution)

Examples:
  # Deploy VersionRegistry
  CHAIN_KEY=ethereum-sepolia DEPLOYER_PRIVATE_KEY=0x... $0 DeployVersionRegistry --broadcast

  # Upgrade VersionRegistry
  CHAIN_KEY=ethereum-sepolia DEPLOYER_PRIVATE_KEY=0x... $0 UpgradeVersionRegistry --broadcast

  # Set minimum broker version from TOML (edit deployment-version-registry.toml first)
  CHAIN_KEY=ethereum-sepolia DEPLOYER_PRIVATE_KEY=0x... $0 SetMinimumBrokerVersion --broadcast

  # Set minimum broker version via env override
  CHAIN_KEY=ethereum-sepolia DEPLOYER_PRIVATE_KEY=0x... MAJOR=1 MINOR=2 PATCH=3 $0 SetMinimumBrokerVersion --broadcast

  # Set notice from TOML (edit deployment-version-registry.toml first)
  CHAIN_KEY=ethereum-sepolia DEPLOYER_PRIVATE_KEY=0x... $0 SetNotice --broadcast

  # Set notice via env override
  CHAIN_KEY=ethereum-sepolia DEPLOYER_PRIVATE_KEY=0x... NOTICE="Upgrade to v1.3.0 by March 30" $0 SetNotice --broadcast

  # Clear the notice via env override
  CHAIN_KEY=ethereum-sepolia DEPLOYER_PRIVATE_KEY=0x... NOTICE="" $0 SetNotice --broadcast

  # Transfer ownership step 1: initiate (new owner must accept)
  CHAIN_KEY=ethereum-sepolia DEPLOYER_PRIVATE_KEY=0x... NEW_OWNER=0x... $0 TransferVersionRegistryOwnership --broadcast

  # Transfer ownership step 2: accept (run as the new owner)
  CHAIN_KEY=ethereum-sepolia DEPLOYER_PRIVATE_KEY=0x... $0 AcceptVersionRegistryOwnership --broadcast

  # Generate Gnosis Safe calldata for setting version
  CHAIN_KEY=ethereum-sepolia GNOSIS_EXECUTE=true MAJOR=1 MINOR=2 PATCH=3 $0 SetMinimumBrokerVersion

Notes:
  - Network configuration is loaded from deployment.toml and deployment_secrets.toml
  - Private keys must be provided via DEPLOYER_PRIVATE_KEY environment variable
  - All management operations support GNOSIS_EXECUTE=true for Gnosis Safe calldata generation
  - Ownership transfer uses Ownable2Step — new owner must call acceptOwnership()
  - Configuration is read from deployment-version-registry.toml (version, notice, addresses)
  - Env vars (MAJOR/MINOR/PATCH, NOTICE) override TOML values when set
  - All operations write back to deployment-version-registry.toml after execution
EOF
        exit 0
    fi

    # Load environment variables only when running actual commands
    if [ -n "$STACK_TAG" ]; then
        DEPLOY_KEY=${CHAIN_KEY:?}-${STACK_TAG:?}
    else
        DEPLOY_KEY=${CHAIN_KEY:?}
    fi

    echo "Loading environment variables from deployment TOML files"
    load_env_var "RPC_URL" ".chains[\"${CHAIN_KEY:?}\"].rpc-url" "deployment_secrets.toml"
    load_env_var "ETHERSCAN_API_KEY" ".chains[\"${CHAIN_KEY:?}\"].etherscan-api-key" "deployment_secrets.toml"
    load_env_var "CHAIN_ID" ".deployment[\"${DEPLOY_KEY:?}\"].id" "deployment.toml"

    # Check if we're on the correct network
    CONNECTED_CHAIN_ID=$(cast chain-id --rpc-url ${RPC_URL:?})
    if [[ "${CONNECTED_CHAIN_ID:?}" != "${CHAIN_ID:?}" ]]; then
        echo -e "${RED}Error: connected chain id and configured chain id do not match: ${CONNECTED_CHAIN_ID:?} != ${CHAIN_ID:?} ${NC}"
        exit 1
    fi

    local target="${SCRIPT_FILE:?}:${script_function:?}"
    echo "Running forge script $target"

    if [ $FIREBLOCKS -gt 0 ]; then
        # Check for fireblocks
        if ! command -v fireblocks-json-rpc &> /dev/null
        then
            echo "fireblocks-json-rpc not found"
            echo "can be installed with npm install -g @fireblocks/fireblocks-json-rpc"
            exit 1
        fi

        # Run forge via fireblocks
        fireblocks-json-rpc --verbose --rpcUrl ${RPC_URL:?} --http --apiKey ${FIREBLOCKS_API_KEY:?} -- \
            forge script ${FORGE_SCRIPT_FLAGS} \
            --slow --unlocked \
            --etherscan-api-key=${ETHERSCAN_API_KEY:?} \
            --rpc-url {} \
            "$target" "$@"
    else
        # Run forge
        forge script ${FORGE_SCRIPT_FLAGS} \
            --private-key=${DEPLOYER_PRIVATE_KEY:?} \
            --etherscan-api-key=${ETHERSCAN_API_KEY:?} \
            --rpc-url ${RPC_URL:?} \
            "$target" "$@"
    fi
}

# Run from the repo root for consistency.
cd ${REPO_ROOT_DIR:?}

# Get current git commit hash for deployment tracking
CURRENT_COMMIT=$(git rev-parse --short HEAD)
export CURRENT_COMMIT

forge_script "$@"
